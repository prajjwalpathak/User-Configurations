    "Sieve Of Eratosthenes": {
        "prefix": "soe",
        "body": [
            "vector<bool> is_prime;",
            "",
            "void sieveOfEratosthenes(int n)",
            "{",
            "    is_prime.resize(n + 1, true);",
            "    is_prime[0] = false;",
            "    is_prime[1] = false;",
            "",
            "    for (int i = 2; i * i <= n; i++)",
            "    {",
            "        if (is_prime[i])",
            "        {",
            "            for (int j = i * i; j <= n; j += i)",
            "            {",
            "                is_prime[j] = false;",
            "            }",
            "        }",
            "    }",
            "}"
        ],
        "description": "Sieve Of Eratosthenes"
    },
    "Prime Factorization": {
        "prefix": "soepf",
        "body": [
            "// Smallest Prime Factor (SOE)",
            "const int MAXINT = 10000001;",
            "vector<int> spf(MAXINT);",
            "",
            "void sieveOfEratosthenesSPF()",
            "{",
            "    for (int i = 0; i < MAXINT; i++)",
            "    {",
            "        spf[i] = i;",
            "    }",
            "",
            "    for (int i = 2; i * i < MAXINT; i++)",
            "    {",
            "        if (spf[i] == i)",
            "        {",
            "            for (int j = i * i; j < MAXINT; j += i)",
            "            {",
            "                if (spf[j] == j)",
            "                {",
            "                    spf[j] = i;",
            "                }",
            "            }",
            "        }",
            "    }",
            "}",
            "",
            "// Factors of a Number (Factorization) (SOE)",
            "vector<int> factors;",
            "",
            "void getFactorization(int n)",
            "{",
            "    factors.clear();",
            "    while (n != 1)",
            "    {",
            "        factors.emplace_back(spf[n]);",
            "        n /= spf[n];",
            "    }",
            "}"
        ],
        "description": "Prime Factorization using SOE"
    }
