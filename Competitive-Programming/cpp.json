        "prefix": "gcd",
        "body": [
            "int gcd(int a, int b)",
            "{",
            "    while (b)",
            "    {",
            "        a %= b;",
            "        swap(a, b);",
            "    }",
            "    return a;",
            "}"
        ],
        "description": "GCD"
